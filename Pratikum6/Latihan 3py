def insertion_sort(data):
    for i in range(1, len(data)):
        key = data[i]
        j = i - 1
        while j >= 0 and data[j] > key:
            data[j + 1] = data[j]
            j -= 1
        data[j + 1] = key
        # Print setiap langkah untuk tracing
        print(f"Langkah {i}: {data}")

data = [5, 2, 4, 6, 1, 3]
print("Data awal:", data)
insertion_sort(data)



